# Copy these to Railway service variables (API service)
# DATABASE_URL is auto-injected when you link PostgreSQL

JWT_SECRET=generate-with-openssl-rand-hex-32
JWT_REFRESH_SECRET=generate-with-openssl-rand-hex-32
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
NODE_ENV=production
CORS_ORIGIN=*
RUN_SEED=true

# After first successful deploy, set RUN_SEED=false and redeploy
