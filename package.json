{
  "name": "shopcount",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w @shopcount/api",
    "dev:mobile": "npm run start -w @shopcount/mobile",
    "build": "npm run build -w @shopcount/types && npm run build -w @shopcount/api",
    "start:api": "npm run start:prod -w @shopcount/api",
    "start:api:seed": "npm run start:prod:seed -w @shopcount/api",
    "deploy:railway": "railway up",
    "test": "npm run test -w @shopcount/api && npm run test -w @shopcount/mobile",
    "db:generate": "npm run db:generate -w @shopcount/api",
    "db:migrate": "npm run db:migrate -w @shopcount/api",
    "db:seed": "npm run db:seed -w @shopcount/api",
    "lint": "npm run lint --workspaces --if-present"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-reanimated": "4.5.0"
  },
  "devDependencies": {
    "@railway/cli": "^5.23.3"
  }
}
